	measure '_SVG_(Down 3 Bookmakers)' = ```
			
			-- ---------------------------------------------------------
			-- 1. CONFIGURATION & RANG
			-- ---------------------------------------------------------
			VAR RangDuFlop = SELECTEDVALUE(Dim_Podium[Rang])
			VAR CouleurFond   = [_COULEUR_(Negatif)]  -- Couleur différente pour le flop
			VAR CouleurChiffre = "#FFFFFF"
			VAR CouleurTexte   = "#666666"
			VAR CouleurKPI    = "#666666"
			
			-- Tailles adaptées au format compact
			VAR TailleCarre   = 22
			VAR TailleChiffre = "14px"
			VAR TailleTexte   = "11px"
			VAR TailleKPI     = "9px"
			VAR Arrondi       = 4
			
			-- Positionnement ajusté avec plus d'espace
			VAR PosXTexte     = 40  
			VAR PosYTexte     = 17  
			VAR HauteurSVG    = 30
			VAR LargeurSVG    = 130 
			
			-- ---------------------------------------------------------
			-- 2. LOGIQUE : DYNAMISATION DU KPI (ORDRE INVERSE)
			-- ---------------------------------------------------------
			VAR NomKPISel = SELECTEDVALUE('Dim_KPI'[Nom_KPI], "KPI_(Profits)")
			
			-- On crée la table avec bookmaker et sa valeur
			VAR TableAvecValeurs = 
			    ADDCOLUMNS(
			        SUMMARIZE(Fact_BDD, Fact_BDD[Bookmaker]),
			        "@Valeur", 
			[_KPI_(Choix)]
			    )
			
			-- On filtre pour garder seulement les bookmakers avec une valeur
			VAR TableFiltree = FILTER(TableAvecValeurs, NOT(ISBLANK([@Valeur])))
			
			-- On ajoute le rang INVERSÉ (ASC au lieu de DESC)
			VAR TableAvecRang = 
			    ADDCOLUMNS(
			        TableFiltree,
			        "@Rang", RANKX(TableFiltree, [@Valeur], , ASC, DENSE)
			    )
			
			-- On récupère le bookmaker et la valeur correspondant au rang
			VAR LigneSelectionnee = FILTER(TableAvecRang, [@Rang] = RangDuFlop)
			
			VAR NomBookmaker = MAXX(LigneSelectionnee, Fact_BDD[Bookmaker])
			
			VAR ValeurKPI = MAXX(LigneSelectionnee, [@Valeur])
			
			-- Format récupéré depuis la table Dim_KPI
			VAR FormatKPISel = SELECTEDVALUE(Dim_KPI[Format_KPI], "#,##0.00 €")
			
			-- Formatage dynamique de la valeur
			VAR ValeurFormatee =
			    FORMAT(ValeurKPI, FormatKPISel)
			
			-- ---------------------------------------------------------
			-- 3. RENDU : CONSTRUCTION DU SVG
			-- ---------------------------------------------------------
			VAR CentreCarreX = 5 + (TailleCarre / 2)
			VAR CentreCarreY = 4 + (TailleCarre / 2)
			
			VAR CodeSVG = 
			    "data:image/svg+xml;utf8," & 
			    "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 " & LargeurSVG & " " & HauteurSVG & "'>" & 
			        "<rect x='5' y='4' width='" & TailleCarre & "' height='" & TailleCarre & "' rx='" & Arrondi & "' " &
			        "fill='" & CouleurFond & "' />" & 
			        "<text x='" & CentreCarreX & "' y='" & CentreCarreY + 1 & "' text-anchor='middle' dominant-baseline='middle' " & 
			        "style='font-family:Segoe UI, Arial, sans-serif; font-weight:900; font-size:" & TailleChiffre & ";' fill='" & CouleurChiffre & "'>" & 
			        RangDuFlop & "</text>" & 
			        "<text x='" & PosXTexte & "' y='" & PosYTexte & "' text-anchor='start' dominant-baseline='middle' " & 
			        "style='font-family:Segoe UI, Arial, sans-serif; font-weight:700; font-size:" & TailleTexte & ";' fill='" & CouleurTexte & "'>" & 
			        NomBookmaker & 
			        "<tspan dx='5' style='font-weight:400; font-size:" & TailleKPI & ";' fill='" & CouleurKPI & "'>" & ValeurFormatee & "</tspan>" &
			        "</text>" & 
			    "</svg>"
			
			RETURN
			IF(ISBLANK(NomBookmaker), BLANK(), CodeSVG)
			```
		displayFolder: Bookmaker
		lineageTag: 5d1216d3-7e3e-4eb9-8fca-b0ab10c821cc
		dataCategory: ImageUrl

	measure _KPI_(Choix) = ```
			
			
			VAR NomKPISel = SELECTEDVALUE('Dim_KPI'[Nom_KPI], "KPI_(Profits)")
			
			RETURN
			        
			        CALCULATE(
			            SWITCH(
			                NomKPISel,
			                "KPI_(Paris)", [_KPI_(Paris)],
			                "KPI_(Taux Reussite %)", [_KPI_(Taux Reussite %)],
			                "KPI_(ROI)", [_KPI_(ROI)],
			                "KPI_(Profits)", [_KPI_(Profits)],
			                "KPI_(Mise Totale)", [_KPI_(Mise Totale)],
			                "KPI_(Gain Total)", [_KPI_(Gain Total)],
			                "KPI_(Cote Moyenne)", [_KPI_(Cote Moyenne)],
			                "KPI_(Cote Moyenne Gagné)", [_KPI_(Cote Moyenne Gagné)],
			                "KPI_(Cote Moyenne Perdu)", [_KPI_(Cote Moyenne Perdu)],
			                "KPI_(Paris % Classique)", [_KPI_(Paris % Classique)],
			                [_KPI_(Profits)]
			            )
			        )
			```
		displayFolder: KPI
		lineageTag: 8b20f4ba-ae08-4fac-ab66-4092afed4b35

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '_COULEUR_(Tableau Bookmaker KPI 2 ROI)' = ```
			
			
			-- 1. Identification du KPI sélectionné
			VAR _KPI_Actuel = SELECTEDVALUE(Dim_KPI[Nom_KPI])
			VAR _EstROI = (_KPI_Actuel = "KPI_(ROI)")
			
			-- 2. Logique de couleurs pour le ROI (Ta nouvelle palette)
			VAR PaletteViolet = 
			    SWITCH(TRUE(),
			        ISINSCOPE(Dim_Bookmaker[Bookmaker]), [_COULEUR_(KPI Tableau Fond Ss Cat)],
			        ISINSCOPE(Dim_Bookmaker[Type_Bookmaker]) && SELECTEDVALUE(Dim_Bookmaker[Type_Bookmaker]) = "Hors Arjel", [_COULEUR_(KPI Tableau Fond Cat)],
			        ISINSCOPE(Dim_Bookmaker[Type_Bookmaker]) && SELECTEDVALUE(Dim_Bookmaker[Type_Bookmaker]) = "Arjel", [_COULEUR_(KPI Tableau Fond Cat)],
			        [_COULEUR_(KPI Tableau Fond Total)]
			    )
			
			-- 3. Logique de couleurs standard (Ton ancienne palette - À AJUSTER)
			VAR PaletteStandard = 
			    SWITCH(TRUE(),
			        ISINSCOPE(Dim_Bookmaker[Bookmaker]), [_COULEUR_(KPI No Tableau Fond Ss Cat)],
			        ISINSCOPE(Dim_Bookmaker[Type_Bookmaker]) && SELECTEDVALUE(Dim_Bookmaker[Type_Bookmaker]) = "Hors Arjel", [_COULEUR_(KPI No Tableau Fond Cat)],
			        ISINSCOPE(Dim_Bookmaker[Type_Bookmaker]) && SELECTEDVALUE(Dim_Bookmaker[Type_Bookmaker]) = "Arjel", [_COULEUR_(KPI No Tableau Fond Cat)],
			        [_COULEUR_(KPI No Tableau Fond Total)]
			    )
			
			-- 4. Choix de la palette selon le contexte
			RETURN
			IF(_EstROI,  PaletteViolet,PaletteStandard)
			```
