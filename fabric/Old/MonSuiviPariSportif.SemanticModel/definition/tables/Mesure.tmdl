			        "KPI_(Paris)","#,##0",
			
			        "KPI_(Taux Reussite %)","0.00 %",
			
			        "KPI_(ROI)","0.00 %",
			
			        "KPI_(Profits)","#,##0.00 €",
			
			        "KPI_(Mise Totale)","#,##0.00 €",
			
			        "KPI_(Gain Total)","#,##0.00 €",
			
			        "KPI_(Cote Moyenne)", "0.00",
			
			        "KPI_(Cote Moyenne Gagné)", "0.00",
			
			        "KPI_(Cote Moyenne Perdu)""0.00",
			
			        "KPI_(Paris % Classique)", "0.00 %",
			
			"#,##0.00 €"
			    )
			)
