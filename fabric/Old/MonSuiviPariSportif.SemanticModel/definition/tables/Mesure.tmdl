	measure '_SVG_(Top 3 Bookmakers)' = ```
			
			-- ---------------------------------------------------------
			-- 1. CONFIGURATION & RANG
			-- ---------------------------------------------------------
			VAR RangDuPodium = SELECTEDVALUE(Dim_Podium[Rang])
			VAR CouleurFond   = [_COULEUR_(Positif)]
			VAR CouleurChiffre = "#FFFFFF"
			VAR CouleurTexte   = "#666666"
			VAR CouleurKPI    = "#666666"
			
			-- Tailles adaptées au format compact
			VAR TailleCarre   = 22
			VAR TailleChiffre = "14px"
			VAR TailleTexte   = "11px"
			VAR TailleKPI     = "9px"
			VAR Arrondi       = 4
			
			-- Positionnement ajusté avec plus d'espace
			VAR PosXTexte     = 40  
			VAR PosYTexte     = 17  
			VAR HauteurSVG    = 30
			VAR LargeurSVG    = 130 
			
			-- ---------------------------------------------------------
			-- 2. LOGIQUE : DYNAMISATION DU KPI
			-- ---------------------------------------------------------
			VAR NomKPISel = SELECTEDVALUE('Dim_KPI'[Nom_KPI], "KPI_(Profits)")
			
			-- On crée la table avec bookmaker et sa valeur
			VAR TableAvecValeurs = 
			    ADDCOLUMNS(
			        SUMMARIZE(Fact_BDD, Fact_BDD[Bookmaker]),
			        "@Valeur", 
			[_KPI_(Choix)]
			    )
			
			-- On filtre pour garder seulement les bookmakers avec une valeur
			VAR TableFiltree = FILTER(TableAvecValeurs, NOT(ISBLANK([@Valeur])))
			
			-- On ajoute le rang
			VAR TableAvecRang = 
			    ADDCOLUMNS(
			        TableFiltree,
			        "@Rang", RANKX(TableFiltree, [@Valeur], , DESC, DENSE)
			    )
			
			-- On récupère le bookmaker et la valeur correspondant au rang
			VAR LigneSelectionnee = FILTER(TableAvecRang, [@Rang] = RangDuPodium)
			
			VAR NomBookmaker = MAXX(LigneSelectionnee, Fact_BDD[Bookmaker])
			
			VAR ValeurKPI = MAXX(LigneSelectionnee, [@Valeur])
			
			-- Format récupéré depuis la table Dim_KPI
			VAR FormatKPISel = SELECTEDVALUE(Dim_KPI[Format_KPI], "#,##0.00 €")
			
			-- Formatage dynamique de la valeur
			VAR ValeurFormatee =
			    FORMAT(ValeurKPI, FormatKPISel)
			
			
			-- ---------------------------------------------------------
			VAR CentreCarreX = 5 + (TailleCarre / 2)
			VAR CentreCarreY = 4 + (TailleCarre / 2)
			
			VAR CodeSVG = 
			    "data:image/svg+xml;utf8," & 
			    "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 " & LargeurSVG & " " & HauteurSVG & "'>" & 
			        "<rect x='5' y='4' width='" & TailleCarre & "' height='" & TailleCarre & "' rx='" & Arrondi & "' " &
			        "fill='" & CouleurFond & "' />" & 
			        "<text x='" & CentreCarreX & "' y='" & CentreCarreY + 1 & "' text-anchor='middle' dominant-baseline='middle' " & 
			        "style='font-family:Segoe UI, Arial, sans-serif; font-weight:900; font-size:" & TailleChiffre & ";' fill='" & CouleurChiffre & "'>" & 
			        RangDuPodium & "</text>" & 
			        "<text x='" & PosXTexte & "' y='" & PosYTexte & "' text-anchor='start' dominant-baseline='middle' " & 
			        "style='font-family:Segoe UI, Arial, sans-serif; font-weight:700; font-size:" & TailleTexte & ";' fill='" & CouleurTexte & "'>" & 
			        NomBookmaker & 
			        "<tspan dx='5' style='font-weight:400; font-size:" & TailleKPI & ";' fill='" & CouleurKPI & "'>" & ValeurFormatee & "</tspan>" &
			        "</text>" & 
			    "</svg>"
			
			RETURN
			IF(ISBLANK(NomBookmaker), BLANK(), CodeSVG)
			```
		displayFolder: Bookmaker
		lineageTag: e5f6a7b8-c9da-4bec-af40-5b6c7d8e9fa0
		dataCategory: ImageUrl

