	measure '_SVG_(Résultat Pari Tableau)' = ```
			
			
			VAR Resultat = MAX ( Fact_BDD[Résultat] )
			
			-- Couleur principale selon le résultat
			VAR Couleur =
			    SWITCH (
			        Resultat,
			        "Gagné", [_COULEUR_(Positif)],
			        "Perdu", [_COULEUR_(Negatif)],
			        "Remboursé/Annulé", "#6c757d",
			        "#000000"
			    )
			
			-- Profit brut
			VAR ProfitBrut = [_KPI_(Profits)]
			
			-- Profit formaté (+ / -) uniquement si gagné ou perdu et non nul
			VAR ProfitFormate =
			    IF (
			        Resultat <> "Remboursé/Annulé" && ProfitBrut <> 0,
			        FORMAT ( ProfitBrut, "+#,##0.00 €;-#,##0.00 €" ),
			        BLANK ()
			    )
			
			-- Couleur du profit (indépendante du statut)
			VAR CouleurProfit =
			    IF ( ProfitBrut > 0, [_COULEUR_(Positif)], [_COULEUR_(Negatif)] )
			
			-- Rectangle
			VAR Box =
			    "<rect x='1' y='1' rx='10' ry='10' width='115' height='18' 
			        fill='" & Couleur & "' 
			        fill-opacity='0.15' 
			        stroke='" & Couleur & "' 
			        stroke-width='1.5' />"
			
			-- Texte SVG (Résultat + Profit)
			VAR Callout =
			    "<text x='55' y='14' 
			        fill='" & Couleur & "' 
			        font-size='9' 
			        font-weight='bold' 
			        font-family='Segoe UI, sans-serif' 
			        text-anchor='middle'>" &
			            Resultat &
			            IF (
			                NOT ISBLANK ( ProfitFormate ),
			                "<tspan dx='6' font-weight='600' fill='" & CouleurProfit & "'>" &
			                    ProfitFormate &
			                "</tspan>",
			                ""
			            ) &
			    "</text>"
			
			RETURN
			IF (
			    HASONEVALUE ( Fact_BDD[Résultat] ),
			    "data:image/svg+xml;utf8," &
			        "<svg xmlns='http://www.w3.org/2000/svg' width='200' height='20' viewBox='0 0 200 20'>" &
			            Box & Callout &
			        "</svg>",
			    BLANK ()
			)
			
			```
		displayFolder: Autres
		lineageTag: 9c206b7b-c15a-49b6-a315-0df7de15b24d
		dataCategory: ImageUrl

	measure '_FILTRE_(Derniers 5 Paris Tableau)' = ```
			
			
			VAR IndexActuel = MAX(Fact_BDD[Index]) -- Ou le nom de votre colonne Index
			
			-- On compte combien d'index sont supérieurs ou égaux à l'index de la ligne actuelle
			VAR Rang = 
			    COUNTROWS(
			        FILTER(
			            ALLSELECTED(Fact_BDD),
			            Fact_BDD[Index] >= IndexActuel
			        )
			    )
			
			RETURN
			IF(Rang <= 5, 1, 0)
			```
		formatString: 0
		displayFolder: Autres
		lineageTag: bb81eb3e-0e40-4f43-9a0c-4c2d6e8d71e5

	measure _PICTO_(Neutre) = ```
			
