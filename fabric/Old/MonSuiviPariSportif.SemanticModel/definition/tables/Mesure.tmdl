table Mesure
	lineageTag: 57679850-7224-45d6-a9ae-cfd5570f1629

	/// Génère un affichage HTML stylisé des filtres actuellement appliqués (Date, Bookmaker, Type de Pari, Sport, Cotes). Affiche 'Tous' si aucun filtre n'est actif.
	measure '_HTML_(FILTRES SELECTIONNES)' = ```
			
							
							
							VAR _font_color = "black"
							VAR _background_color = "#F5F8FB"
							
							
							VAR _1_ = SELECTEDVALUE('Dim_Date'[Date])
							VAR _2_ = SELECTEDVALUE('Dim_Bookmaker'[Bookmaker])
							VAR _3_ = SELECTEDVALUE('Dim_TypeBet'[Boost])
							VAR _4_ = SELECTEDVALUE('Dim_Sport'[Sport])
							VAR _5_ = SELECTEDVALUE('Fact_BDD'[Cote])
							VAR _6_ = ""
							VAR _7_ = ""
							VAR _8_ = ""
							VAR _9_ = ""
							
							
							-- Defines the HTML styling for the filter display. Ensure consistency with the report's design and readability.
							VAR htmlStyle = 
							    "<span style='
							        display:inline-block; 
							        background-color:linear-gradient(135deg,#FFFFFF 0%,rgba(249,250,251,0.3) 100%); 
							        color:"&_font_color&"; 
							        padding:3.5px 7px; 
							        border-radius:5px; 
							        border: 2px solid #E5E7EB; 
							        margin-right:6px; 
							        line-height:1.25; 
							        white-space: nowrap; 
							        overflow: hidden; 
							        text-overflow: ellipsis; 
							        max-width: 1550px;
							        font-size:9px;
							    '>"
							
							
			VAR Html_1 =
			VAR _MinSelected =
			    CALCULATE (
			        MIN ( 'Dim_Date'[Date] ),
			        ALLSELECTED ( 'Dim_Date' )
			    )
			
			VAR _MaxSelected =
			    CALCULATE (
			        MAX ( 'Dim_Date'[Date] ),
			        ALLSELECTED ( 'Dim_Date' )
			    )
			
			VAR _MinAll =
			    CALCULATE (
			        MIN ( 'Dim_Date'[Date] ),
			        ALL ( 'Dim_Date' )
			    )
			
			VAR _MaxAll =
			    CALCULATE (
			        MAX ( 'Dim_Date'[Date] ),
			        ALL ( 'Dim_Date' )
			    )
			
			RETURN
			IF (
			    _MinSelected = _MinAll
			        && _MaxSelected = _MaxAll,
			
			    -- 🔹 Aucun filtre réel
			    BLANK (),
			
			    -- 🔹 Filtré
			    htmlStyle
			        & "<b><i class='fa fa-globe'></i> Date :</b> "
			        & FORMAT ( _MinSelected, "dd/MM/yyyy" )
			        & " → "
			        & FORMAT ( _MaxSelected, "dd/MM/yyyy" )
			        & "</span>"
			)
			
							
			VAR Html_2 = 
			IF (
			    ISFILTERED ( 'Dim_Bookmaker'[Bookmaker] )
			        || ISFILTERED ( 'Dim_Bookmaker'[Type_Bookmaker] ),
			
			    VAR _Table =
			        ADDCOLUMNS (
			            VALUES ( 'Dim_Bookmaker'[Type_Bookmaker] ),
			
			            "NbTotal",
			                CALCULATE (
			                    DISTINCTCOUNT ( 'Dim_Bookmaker'[Bookmaker] ),
			                    ALLEXCEPT (
			                        'Dim_Bookmaker',
			                        'Dim_Bookmaker'[Type_Bookmaker]
			                    )
			                ),
			
			            "NbSelected",
			                CALCULATE (
			                    DISTINCTCOUNT ( 'Dim_Bookmaker'[Bookmaker] )
			                ),
			
			            "ListSelected",
			                CONCATENATEX (
			                    VALUES ( 'Dim_Bookmaker'[Bookmaker] ),
			                    'Dim_Bookmaker'[Bookmaker],
			                    ", "
			                )
			        )
			
			    VAR _DisplayText =
			        CONCATENATEX (
			            FILTER ( _Table, [NbSelected] > 0 ),
			            IF (
			                [NbSelected] = [NbTotal],
			                "<b>Type de Bookmaker:</b> " & 'Dim_Bookmaker'[Type_Bookmaker],
			                "<b>Bookmaker :</b> " & [ListSelected]
			            ),
			            " | "
			        )
			
			    RETURN
			        htmlStyle
			            & _DisplayText
			            & "</span>",
			
			    BLANK ()
			)
							
							VAR Html_3 =
							    IF(
							        ISFILTERED('Dim_TypeBet'[Boost]),
							        VAR Html_3 = ALLSELECTED('Dim_TypeBet'[Boost])  
							        RETURN
							            htmlStyle & "<b><i class='fa fa-globe'></i>Type de pari:</b> " & 
							            CONCATENATEX(Html_3, 'Dim_TypeBet'[Boost], ", ") & "</span>",
							        BLANK()
							    )
							
							VAR Html_4 =
							    IF(
							        ISFILTERED('Dim_Sport'[Sport]),
							        VAR Html_4 = ALLSELECTED('Dim_Sport'[Sport])  
							        RETURN
							            htmlStyle & "<b><i class='fa fa-user'></i>Sport:</b> " & 
							            CONCATENATEX(Html_4, 'Dim_Sport'[Sport], ", ") & "</span>",
							        BLANK()
							    )
							
			VAR Html_5 =
			VAR _MinSelected =
			    CALCULATE (
			        MIN ( 'Dim_Odds'[Odds] ),
			        ALLSELECTED ( 'Dim_Odds' )
			    )
			
			VAR _MaxSelected =
			    CALCULATE (
			        MAX ( 'Dim_Odds'[Odds] ),
			        ALLSELECTED ( 'Dim_Odds' )
			    )
			
			VAR _MinAll =
			    CALCULATE (
			        MIN ( 'Dim_Odds'[Odds] ),
			        ALL ( 'Dim_Odds' )
			    )
			
			VAR _MaxAll =
			    CALCULATE (
			        MAX ( 'Dim_Odds'[Odds] ),
			        ALL ( 'Dim_Odds' )
			    )
			
			RETURN
			IF (
			    _MinSelected = _MinAll
			        && _MaxSelected = _MaxAll,
			
			    -- 🔹 Aucun filtre réel
			    BLANK (),
			
			    -- 🔹 Filtré
			    htmlStyle
			        & "<b><i class='fa fa-user'></i> Cotes :</b> "
			        & FORMAT ( _MinSelected, "0.00" )
			        & " → "
			        & FORMAT ( _MaxSelected, "0.00" )
			        & "</span>"
			)
							
							
				/*			VAR Html_6 =
							    IF(
							        ISFILTERED('BDD'[Cote]),
							        VAR Html_6 = ALLSELECTED('BDD'[Cote])  
							        RETURN
							            htmlStyle & "<b><i class='fa fa-user'></i> Segment SIM:</b> " & 
							            CONCATENATEX(Html_6, 'BDD'[Cote], ", ") & "</span>",
							        BLANK()
							    )
			
			    */
			
			
							
							VAR _No_Filter = htmlStyle & "<b><i class='fa fa-user'></i> Tout</b></span>"
							
							-- Combines all filter sections into a single output.
							VAR CombinedFilterSummary = Html_1 & Html_2 & Html_3 & Html_4 & Html_5
							    
							RETURN
							
							IF(ISBLANK(CombinedFilterSummary),_No_Filter,CombinedFilterSummary)
			```
		displayFolder: Autres
		lineageTag: 4bcb67a4-1f7e-4257-a24e-0e1f29c14076

	/// Calcule le taux de réussite des paris : nombre de paris gagnants divisé par le nombre total de paris avec résultats. Retourne 'Nd' si aucune donnée disponible.
	measure '_KPI_(Taux Reussite %)' =
			
			
			
			VAR _Part =
			
			COALESCE(CALCULATE(COUNT(Fact_BDD[Événement]), Fact_BDD[Résultat] = "Gagné"),0)
			
			/
			
			CALCULATE(COUNT(Fact_BDD[Événement]), Fact_BDD[Résultat]<>"")
			
			
			RETURN
			
			IF(ISBLANK(_Part),"Nd", _Part )
		formatString: 0.0\ %;-0.0\ %;0.0\ %
		displayFolder: KPI
		lineageTag: b42daf9a-69ee-42ab-a214-b1b72c84620b

	/// Calcule le retour sur investissement (ROI) : (Gain Total - Mise Totale) / Mise Totale. Exprimé en pourcentage.
	measure _KPI_(ROI) =
			
			
			([_KPI_(Gain Total)] - [_KPI_(Mise Totale)]) / [_KPI_(Mise Totale)]
		formatString: 0.0\ %;-0.0\ %;0.0\ %
		displayFolder: KPI
		lineageTag: d72356e7-13ef-4d7e-a190-5beb3d4fef06

	/// Compte le nombre total de paris (événements) dans le contexte de filtre actuel.
	measure _KPI_(Paris) =
			
			
			CALCULATE(COUNT(Fact_BDD[Événement]))
		formatString: 0
		displayFolder: KPI
		lineageTag: e489f557-a3d7-4c91-a5d7-38afcea8657b

	/// Calcule le profit net : différence entre les Gains Totaux et les Mises Totales.
	measure _KPI_(Profits) =
			
			
			IF(SELECTEDVALUE(Fact_BDD[Boost])="Mise Freebet" && SELECTEDVALUE(Fact_BDD[Résultat])="Gagné",[_KPI_(Gain Total)],
			[_KPI_(Gain Total)]-[_KPI_(Mise Totale)])
		formatString: #,0\ "€";-#,0\ "€";#,0\ "€"
		displayFolder: KPI
		lineageTag: 09a033ea-4231-4d79-9950-ba75b6defc15

	/// Somme totale des mises placées. Retourne 0 si aucune donnée.
	measure '_KPI_(Mise Totale)' =
			
			
			COALESCE(CALCULATE(SUM(Fact_BDD[Mise])),0)
		formatString: #,0\ "€";-#,0\ "€";#,0\ "€"
		displayFolder: KPI
		lineageTag: b07baa29-cc9e-4660-9ab1-7b13b323176f

	/// Somme totale des gains obtenus. Retourne 0 si aucune donnée.
	measure '_KPI_(Gain Total)' =
			
			
			COALESCE(CALCULATE(SUM(Fact_BDD[Gain])),0)
		formatString: #,0\ "€";-#,0\ "€";#,0\ "€"
		displayFolder: KPI
		lineageTag: 6ad09c73-76c9-4466-861e-d387abf68d60

	/// Calcule le profit cumulé jusqu'à la date maximale sélectionnée. Permet de visualiser l'évolution du profit dans le temps.
	measure '_KPI_(Profits Cumules)' =
			
			
			CALCULATE(
			    [_KPI_(Profits)],
			    FILTER(
			        ALL(Dim_Date),
			        Dim_Date[Date] <= MAX(Dim_Date[Date])
			    )
			)
		formatString: #,0\ "€";-#,0\ "€";#,0\ "€"
		displayFolder: KPI
		lineageTag: fe7f21ea-bc9f-4ba9-a14b-92c28475e380

	/// Retourne 'rouge' si les profits sont négatifs, 'vert' si positifs ou nuls. Utilisé pour la mise en forme conditionnelle.
	measure '_KPI_(Profits Couleur)' =
			
			
			SWITCH(TRUE(),
			[_KPI_(Profits)]<0, [_COULEUR_(Negatif)],
			[_KPI_(Profits)]>=0, [_COULEUR_(Positif)],
			"")
		displayFolder: KPI
		lineageTag: 0838687a-a196-4f5a-9afa-0423781a8978

	/// Retourne 'rouge' si le ROI est négatif, 'vert' si positif ou nul. Utilisé pour la mise en forme conditionnelle.
	measure '_KPI_(ROI Couleur)' =
			
			
			SWITCH(TRUE(),
			[_KPI_(ROI)]<0, [_COULEUR_(Negatif)],
			[_KPI_(ROI)]>=0, [_COULEUR_(Positif)],
			"")
		displayFolder: KPI
		lineageTag: b93a606c-7330-45b5-bae0-8ec38c10d6ae

	/// Retourne 'rouge' si le taux de réussite est inférieur à 50%, 'vert' si supérieur ou égal à 50%. Utilisé pour la mise en forme conditionnelle.
	measure '_KPI_(Taux Reussite Couleur)' =
			
			
			SWITCH(TRUE(),
			[_KPI_(Taux Reussite %)]<0.5, [_COULEUR_(Negatif)],
			[_KPI_(Taux Reussite %)]>=0.5, [_COULEUR_(Positif)],
			"")
		displayFolder: KPI
		lineageTag: 81d9538c-e010-429c-8897-091054bc6e21

	/// Retourne le code couleur vert pour les valeurs positives dans la mise en forme conditionnelle.
	measure _COULEUR_(Positif) =
			
			
			"#3CBFA5"
		displayFolder: Parametre
		lineageTag: 0c64937f-2d0b-4c9c-98c0-e03eb872503e

	/// Retourne le code couleur rouge pour les valeurs négatives dans la mise en forme conditionnelle.
	measure _COULEUR_(Negatif) =
			
			
			"#C73659"
		displayFolder: Parametre
