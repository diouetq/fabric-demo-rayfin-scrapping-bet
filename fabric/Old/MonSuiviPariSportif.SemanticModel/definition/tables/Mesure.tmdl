	measure '_(Logo Linkedin HTML)' = ```
			
			
			// ========== PARAMÈTRES DE TAILLE ==========
			VAR TailleSVG = 30
			VAR WrapperSize = TailleSVG * 1.2
			
			// ========== PARAMÈTRES DE COULEURS ==========
			// Couleurs du logo (état normal)
			VAR CouleurIcone = "#7161EF"           // Couleur du pictogramme "in"
			VAR CouleurCercleInterieur = "white"   // Couleur du cercle intérieur
			VAR CouleurContour = "white"           // Couleur du contour extérieur
			
			// Couleurs au survol
			VAR CouleurIconeSurvol = "white"       // Couleur du pictogramme au survol
			VAR CouleurCercleInterieurSurvol = "transparent"  // Cercle intérieur au survol
			VAR CouleurContourSurvol = "white"     // Contour au survol
			
			// Couleur de fond
			VAR CouleurFond = "transparent"        // Fond du wrapper
			
			VAR CSS =
			"
			<style>
			    html { box-sizing: border-box; font-size: 100%; }
			
			    body {
			        background-position: center center;
			        background-repeat: no-repeat;
			        background-attachment: fixed;
			        background-size: cover;
			        text-align: center;
			        font-family: ""Montserrat"", sans-serif;
			        max-width: 100%;
			        min-height: " & WrapperSize & "px;
			        height: auto;
			        display: flex;
			        justify-content: center;
			        align-items: center;
			        margin: 0;
			        padding: 0;
			        letter-spacing: 0.1em;
			    }
			
			    /* ----- Conteneur global ----- */
			    .wrapper {
			        display: flex;
			        justify-content: space-around;
			        align-items: center;
			        width: " & WrapperSize & "px;
			        height: " & WrapperSize & "px;
			        background-color: " & CouleurFond & ";
			        transition: all 0.4s ease-out;
			    }
			
			    /* ----- Conteneur des liens sociaux ----- */
			    .wrapper__links { 
			        display: flex; 
			        justify-content: space-between; 
			        align-items: center; 
			        width: 70%; 
			    }
			
			    /* ----- Élément principal du lien social ----- */
			    .social-link .social-svg { 
			        width: " & TailleSVG & "px; 
			        height: " & TailleSVG & "px; 
			    }
			
			    /* ======================== COULEURS NORMALES ======================== */
			
			    /* Icône centrale (le in de LinkedIn) */
			    .social-link .social-svg .social-group__icon { 
			        fill: " & CouleurIcone & "; 
			        transition: all 0.2s; 
			    }
			
			    /* Cercle intérieur derrière le pictogramme */
			    .social-link .social-svg .social-group__inner-circle { 
			        fill: " & CouleurCercleInterieur & "; 
			        transition: all 0.2s; 
			    }
			
			    /* Grand cercle extérieur (le contour) */
			    .social-link .social-svg .social-group__outline {
			        stroke: " & CouleurContour & ";
			        transform-origin: 50% 50%;
			        transform: scale(1.1);
			        transition: all 0.2s;
			    }
			
			    /* ======================== COULEURS AU SURVOL ======================== */
			
			    /* Quand on survole : l'icône devient colorée */
			    .social-link .social-svg:hover .social-group__icon, 
			    .social-link .social-svg:active .social-group__icon, 
			    .social-link .social-svg:focus .social-group__icon { 
			        fill: " & CouleurIconeSurvol & "; 
			        transition: all 0.45s; 
			    }
			
			    /* Quand on survole : le cercle intérieur devient transparent */
			    .social-link .social-svg:hover .social-group__inner-circle, 
			    .social-link .social-svg:active .social-group__inner-circle, 
			    .social-link .social-svg:focus .social-group__inner-circle { 
			        fill: " & CouleurCercleInterieurSurvol & "; 
			        transition: all 0.45s; 
			    }
			
			    /* Quand on survole : le contour garde sa couleur et sa taille */
			    .social-link .social-svg:hover .social-group__outline, 
			    .social-link .social-svg:active .social-group__outline, 
			    .social-link .social-svg:focus .social-group__outline { 
			        stroke: " & CouleurContourSurvol & "; 
			        transform: scale(1.1); 
			        transition: all 0.45s; 
			    }
			
			</style>
			"
			
			VAR HTML_ =
			CSS
			& "<html lang='en'>
			<head>
			<meta charset='UTF-8' />
			<meta name='viewport' content='width=device-width, initial-scale=1.0' />
			<title>Linkedin</title>
			</head>
			<body>
			<div class='wrapper'>
			    <div class='wrapper__links'>
			        <a class='social-link social-link--linkedin' href='https://www.linkedin.com/in/quentin-diouet'>
			            <svg class='social-svg' viewBox='0 0 600 600' xmlns='http://www.w3.org/2000/svg' width='" & TailleSVG & "' height='" & TailleSVG & "'>
			                <title>linkedin</title>
			                <g class='social-group' fill='none' fill-rule='evenodd'>
			                    <circle class='social-group__outline' stroke='" & CouleurContour & "' stroke-width='20' cx='300' cy='300' r='262.5' />
			                    <circle class='social-group__inner-circle' fill='" & CouleurCercleInterieur & "' cx='300' cy='300' r='252.5' />
			                    <path class='social-group__icon' 
			                          d='M278.9308 253.1923h43.5769v20.0539h.5923c6.0923-11.5077 20.9-23.6077 43.0692-23.6077 46.0308 0 54.577 30.2923 54.577 69.723v80.2154h-45.4385v-71.1615
			                          c0-17.0077-.2539-38.8385-23.6077-38.8385-23.6923 0-27.2462 18.5308-27.2462 37.5693v72.4307h-45.4384l-.0846-146.3846zm-74.1231 
			                          0h45.523V399.577h-45.523V253.1923zm22.8461-72.7692c14.5539 0 26.4 11.8461 26.4 26.4 
			                          0 14.5538-11.8461 26.4-26.4 26.4-14.6384 0-26.4-11.8462-26.4-26.4 
			                          0-14.5539 11.7616-26.4 26.4-26.4z' 
			                          fill='" & CouleurIcone & "' fill-rule='nonzero'/>
			                </g>
			            </svg>
			        </a>
			    </div>
			</div>
			</body>
			</html>"
			
			RETURN
			HTML_
			```
		displayFolder: Autres
		lineageTag: 7e043065-b2bd-4312-90e8-10c4099dd4b9

