		sourceColumn: [Date Affichage]

		annotation SummarizationSetBy = Automatic

	partition Dim_Date = calculated
		mode: import
		source = ```
				
				VAR DateMin = CALCULATE ( MIN ( Fact_BDD[Date] ), ALL ( Fact_BDD ) )
				VAR DateMax = CALCULATE ( MAX ( Fact_BDD[Date] ), ALL ( Fact_BDD ) )
				
				RETURN
				ADDCOLUMNS (
				    CALENDAR ( DateMin, DateMax ),
				
				    /* 1. ANNÉE */
				    "Année", YEAR ( [Date] ),
				
				    /* 2. TRIMESTRE */
				    "Trimestre", "T" & FORMAT ( [Date], "Q" ),
				    "Trimestre Année", "T" & FORMAT ( [Date], "Q" ) & " " & YEAR ( [Date] ),
				    "Trimestre Tri", YEAR ( [Date] ) * 10 + INT ( FORMAT ( [Date], "Q" ) ),
				
				    /* 3. MOIS */
				    "Mois Numéro", MONTH ( [Date] ),
				    "Mois", FORMAT ( [Date], "MMMM", "fr-FR" ),
				    "Mois Court", FORMAT ( [Date], "MMM", "fr-FR" ),
				    "Mois Année", FORMAT ( [Date], "MMM yyyy", "fr-FR" ),
				    "Mois Année Tri", YEAR ( [Date] ) * 100 + MONTH ( [Date] ),
				
				    /* 4. SEMAINE (ISO Strict) */
				    "Semaine Numéro", 
				        VAR JeudiISO = [Date] - WEEKDAY ( [Date], 2 ) + 4
				        VAR AnneeISO = YEAR ( JeudiISO )
				        VAR JeudiSemaine1 = DATE ( AnneeISO, 1, 4 ) - WEEKDAY ( DATE ( AnneeISO, 1, 4 ), 2 ) + 4
				        RETURN 1 + INT ( ( JeudiISO - JeudiSemaine1 ) / 7 ),
				    "Semaine Année",
				        VAR JeudiISO = [Date] - WEEKDAY ( [Date], 2 ) + 4
				        VAR AnneeISO = YEAR ( JeudiISO )
				        VAR NumSem = 1 + INT ( ( JeudiISO - (DATE ( AnneeISO, 1, 4 ) - WEEKDAY ( DATE ( AnneeISO, 1, 4 ), 2 ) + 4) ) / 7 )
				        RETURN "S" & FORMAT ( NumSem, "00" ) & " " & AnneeISO,
				    "Semaine Tri",
				        VAR JeudiISO = [Date] - WEEKDAY ( [Date], 2 ) + 4
				        VAR AnneeISO = YEAR ( JeudiISO )
				        VAR NumSem = 1 + INT ( ( JeudiISO - (DATE ( AnneeISO, 1, 4 ) - WEEKDAY ( DATE ( AnneeISO, 1, 4 ), 2 ) + 4) ) / 7 )
				        RETURN AnneeISO * 100 + NumSem,
				
				    /* 5. JOUR */
				    "Jour", DAY ( [Date] ),
				    "Jour Semaine Numéro", WEEKDAY ( [Date], 2 ), -- 1 = Lundi
				    "Jour Nom", FORMAT ( [Date], "dddd", "fr-FR" ),
				    "Date Affichage", FORMAT ( [Date], "dd/MM/yyyy" )
				)
				```

	annotation PBI_Id = be748bfe447a41589d84c4366d15ea63

