{
  "name": "scrapping-bet",
  "description": "Paris Sportif - Value Bet — collecte de cotes (Betify, MyStake, Sportaza, Greenluck, Slott), calculs Kelly/TRJ/surebet, suivi des paris et KPI. Fabric App développée avec Rayfin.",
  "license": "MIT",
  "author": {
    "name": "Quentin DIOUET",
    "url": "https://github.com/diouetq"
  },
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "rayfin env --framework vite",
    "prebuild": "rayfin env --framework vite",
    "dev": "vite",
    "build": "tsc -b --noCheck && vite build",
    "build:fabric": "npx rayfin env --framework vite && tsc -b --noCheck && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:fabric": "node scripts/open-fabric-portal.mjs",
    "rayfin:db": "node scripts/rayfin-db-apply.mjs",
    "rayfin:db-slott": "node scripts/patch-dab-scrapping-bet.mjs",
    "rayfin:diag-bdd": "node scripts/diag-bdd.mjs",
    "rayfin:deploy": "npm run build:fabric && npx rayfin up staticapp deploy -y",
    "rayfin:deploy:force": "npm run build:fabric && npx rayfin up staticapp deploy --force -y",
    "rayfin:slott-store": "node scripts/invoke-slott-store.mjs"
  },
  "dependencies": {
    "@microsoft/fabric-embedded-host": "^1.33.2",
    "@microsoft/rayfin-auth-provider-fabric": "^1.32.0",
    "@microsoft/rayfin-client": "^1.32.0",
    "@microsoft/rayfin-core": "^1.32.0",
    "@microsoft/rayfin-data": "^1.32.0",
    "@microsoft/rayfin-lib": "^1.32.0",
    "@tailwindcss/vite": "^4.2.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.0.0",
    "react-dom": "^19.2.5",
    "react-error-boundary": "^6.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@microsoft/rayfin-cli": "^1.23.0",
    "@microsoft/rayfin-mcp": "^1.30.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "rollup-plugin-license": "^3.7.1",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.38.0",
    "vite": "^7.2.6",
    "vitest": "^3.2.2"
  }
}
